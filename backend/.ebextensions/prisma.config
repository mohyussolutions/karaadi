# backend/.ebextensions/prisma.config
#
# Elastic Beanstalk container commands run AFTER the application bundle is
# extracted and BEFORE the web server (Node.js) is (re)started.
#
# • leader_only: true  — runs only on a single instance during rolling deploys,
#   preventing simultaneous migrations that would corrupt the database.
# • All commands run as the ec2-user inside /var/app/staging (the extracted
#   bundle directory) before the app goes live.
#
# Environment variables (DATABASE_URL, REDIS_URL, etc.) are already available
# at this point because Elastic Beanstalk injects them from the
# aws:elasticbeanstalk:application:environment namespace before running hooks.

option_settings:
  # Ensure the app root is where we expect it
  aws:elasticbeanstalk:application:environment:
    NPM_CONFIG_PRODUCTION: "false"   # install devDependencies so prisma CLI is available

container_commands:

  # ── 1. Generate the Prisma client ─────────────────────────────────────────
  # Must run before migrate so the engine binary is present.
  01_prisma_generate:
    command: |
      export HOME=/var/app/staging
      cd /var/app/staging
      npx prisma generate --schema=./src/prisma/schema.prisma
    leader_only: false   # safe to run on every instance — no DB writes

  # ── 2. Apply pending migrations ────────────────────────────────────────────
  # `migrate deploy` is idempotent: it only applies unapplied migrations.
  # Running it on the leader instance prevents race conditions.
  02_prisma_migrate:
    command: |
      export HOME=/var/app/staging
      cd /var/app/staging

      # Wait up to 5 minutes for RDS to be reachable before attempting migration
      echo "[eb] waiting for database connection..."
      for i in $(seq 1 30); do
        if npx prisma migrate status \
            --schema=./src/prisma/schema.prisma \
            2>&1 | grep -qE "(Database schema is up to date|following migration)"; then
          echo "[eb] database reachable on attempt $i"
          break
        fi
        echo "[eb] attempt $i/30 — database not ready, retrying in 10s..."
        sleep 10
      done

      npx prisma migrate deploy --schema=./src/prisma/schema.prisma
    leader_only: true

  # ── 3. Seed / import reference data ────────────────────────────────────────
  # Fixes the P1001 error ("Can't reach database server") that occurs when the
  # seed tries to run from outside the VPC.  Running it here — inside the EB
  # instance — guarantees it executes within the private network.
  #
  # `npm run import` calls: tsx src/prisma/seed.ts
  # The seed script must be idempotent (upsert / skip-if-exists logic).
  03_seed_import:
    command: |
      export HOME=/var/app/staging
      cd /var/app/staging
      echo "[eb] running seed / import..."
      npm run import && echo "[eb] seed completed successfully" \
        || echo "[eb] seed returned non-zero (may be a no-op if data already exists)"
    leader_only: true

  # ── 4. Build TypeScript ────────────────────────────────────────────────────
  # Compile TS to dist/ so that node dist/server.js works.
  04_ts_build:
    command: |
      export HOME=/var/app/staging
      cd /var/app/staging
      npm run build
    leader_only: false

  # ── 5. Restore production-only node_modules (optional optimisation) ────────
  # Re-prune dev dependencies after the build so the running instance is lean.
  05_prune_dev_deps:
    command: |
      cd /var/app/staging
      npm prune --production
    leader_only: false
