    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.4.1",
    "@types/redis": "^4.0.10",
    "@types/socket.io": "^3.0.1",
    "amazon-cognito-identity-js": "^6.3.15",
    "aws-sdk": "^2.1693.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
