{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "main": "server.ts",
  "scripts": {
    "dev": "AWS_SDK_JS_SUPPRESS_MAINTENANCE_MODE_MESSAGE=1 tsx --env-file=.env.local -r tsconfig-paths/register src/server.ts",
    "build": "tsc --project tsconfig.json --noEmit",
    "start": "NODE_ENV=production tsx -r tsconfig-paths/register src/server.ts",
    "prisma:generate": "prisma generate --schema ./src/prisma",
    "db:push": "prisma db push --schema ./src/prisma --accept-data-loss",
    "db:migrate": "prisma migrate dev --schema ./src/prisma",
    "db:studio": "prisma studio --schema ./src/prisma",
    "db:seed": "tsx --env-file=.env.local src/prisma/seed.ts",
    "db:reset": "tsx --env-file=.env.local src/prisma/seed.ts -d",
    "import": "tsx --env-file=.env.local src/prisma/seed.ts",
    "remove": "tsx --env-file=.env.local src/prisma/seed.ts -d",
    "reset": "prisma db push --schema ./src/prisma --force-reset && tsx --env-file=.env.local src/prisma/seed.ts",
    "test": "NODE_OPTIONS='--experimental-vm-modules' npx jest --config jest.config.cjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
