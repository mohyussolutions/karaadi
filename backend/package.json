{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "main": "server.ts",
  "scripts": {
    "dev": "AWS_SDK_JS_SUPPRESS_MAINTENANCE_MODE_MESSAGE=1 tsx -r tsconfig-paths/register src/server.ts",
    "build": "tsc --project tsconfig.json --noEmit",
    "start": "NODE_ENV=production tsx -r tsconfig-paths/register src/server.ts",
    "prisma:generate": "prisma generate --schema=src/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=src/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=src/prisma/schema.prisma",
    "db:seed": "tsx src/prisma/seed.ts",
    "db:reset": "tsx src/prisma/seed.ts -d",
    "import": "tsx src/prisma/seed.ts",
    "remove": "tsx src/prisma/seed.ts -d"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
