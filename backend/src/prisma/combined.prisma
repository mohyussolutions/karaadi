
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Advertisement {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String
  imageUrl    String
  link        String
  buttonText  String?   @default("Learn More")
  isActive    Boolean   @default(true)
  position    String    @default("general")
  priority    Int       @default(1)
  startDate   DateTime?
  endDate     DateTime?
  clicks      Int       @default(0)
  views       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([position])
  @@index([isActive])
  @@index([priority])
  @@index([userId])
}

model Agency {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String
  location  String
  specialty String
  status    String   @default("Verified")
  image     String
  link      String?
  createdAt DateTime @default(now())
  users     User[]   @relation("UserAgencies")
}

model Business {
  id               String    @id @default(cuid())
  userId           String
  name             String
  orgNumber        String?
  email            String
  phone            String
  address          String?
  website          String?
  logo             String?
  images           String[]  @default([])
  description      String?
  categories       String[]
  contactName      String?
  planType             String?
  maxListingsOverride  Int?
  status               String    @default("pending")
  isVerified       Boolean   @default(false)
  isPaid           Boolean   @default(false)
  isAdminEnabled   Boolean   @default(true)
  expiryDate       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  planId           String?
  planStartDate    DateTime?
  plan             BusinessPlan? @relation(fields: [planId], references: [id])
  owner            User          @relation("BusinessOwner", fields: [userId], references: [id], onDelete: Cascade)
  members          User[]        @relation("BusinessMembers")

  @@index([userId])
  @@index([planId])
  @@index([status])
  @@index([isVerified])
  @@index([isAdminEnabled])
  @@index([createdAt])
}
model User {
  id                String          @id @default(uuid())
  cognitoId         String?         @unique
  username          String
  password          String
  email             String?         @unique
  profileImage      String?
  phone             String?
  isAdmin           Boolean         @default(false)
  isManager         Boolean         @default(false)
  isSupport         Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  lastSeenAt        DateTime?       @updatedAt
  
  agencies          Agency[]        @relation("UserAgencies")
  ownedBusinesses   Business[]      @relation("BusinessOwner")
  memberBusinesses  Business[]      @relation("BusinessMembers")
  advertisements    Advertisement[]
  boats             Boat[]          @relation("UserBoats")
  cars              Car[]           @relation("UserCars")
  receivedChats     Chat[]          @relation("receiverChats")
  sentChats         Chat[]          @relation("senderChats")
  cookies           Cookie?         @relation("UserCookies")
  favorites         Favorite[]      @relation("UserFavorites")
  marketplaces      Marketplace[]   @relation("UserMarketplaces")
  receivedMessages  Message[]       @relation("ReceivedMessages")
  sentMessages      Message[]       @relation("SentMessages")
  motorcycles       Motorcycle[]    @relation("UserMotorcycles")
  sentNotifications Notification[]  @relation("SentNotifications")
  receivedNotifications Notification[]  @relation("UserNotifications")
  realEstates       RealEstate[]    @relation("UserRealEstates")
  farmequipments    Farmequipment[] @relation("UserFarmequipments")
  jobs              Job[]           @relation("UserJobs")
  searchLogs        SearchLog[]
  subscriptions     Subscription[]  @relation("UserSubscriptions")
  payments          Payment[]       @relation("UserPayments")
  feeChangeLogs     FeeChangeLog[]
  views             UserView[]
  reports           Report[]        @relation("UserReports")
  

  @@index([email])
  @@index([username])
  @@index([createdAt])

}

model UserView {
  id        Int      @id @default(autoincrement())
  userId    String
  itemId    String
  category  String
  viewedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@index([viewedAt])
  @@map("user_views")
}
model Visitor {
  id        String   @id @default(cuid())
  userId    String   @unique
  ipAddress String?
  userAgent String?
  visitedAt DateTime @default(now())

  @@index([visitedAt])
  @@index([ipAddress])
}

model Cookie {
  id          String   @id @default(cuid())
  userId      String   @unique
  token       String
  accessToken String?  
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation("UserCookies", fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([accessToken])
  @@index([expiresAt])
}model Marketplace {
  id           String    @id @default(cuid())
  userId       String
  businessId   String?
  title        String
  description  String
  price        Float
  mainCategory String
  category     String[]
  subcategory  String[]
  condition    String?
  categoryTag  String?
  website      String?
  region       String
  city         String
  images       String[]
  extra        Json?
  maGaday      Boolean   @default(false)
 isBasic30    Boolean   @default(false)
  isStandard60 Boolean   @default(false)
  isPremium90  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isPaid       Boolean   @default(false)
  expiryDate   DateTime?
  feeId        String?   @unique
  feeAmount    Float     @default(0)
  planId       String?
  planAmount   Float     @default(0)

  user         User      @relation("UserMarketplaces", fields: [userId], references: [id], onDelete: Cascade)
  payments     Payment[] @relation("MarketplacePayments")
  chats        Chat[]
  messages     Message[] @relation("MarketplaceToMessage")
  fee          MarketplaceFee? @relation(fields: [feeId], references: [id])
  plan         SubPlan?  @relation(fields: [planId], references: [id])

  @@index([isPaid])
  @@index([createdAt])
  @@index([userId])
  @@index([region])
  @@index([businessId])
}

model RealEstate {
  id           String    @id @default(cuid())
  userId       String
  businessId   String?
  title        String
  description  String
  price        Float
  mainCategory String
  category     String[]
  subcategory  String[]
  propertyType String?
  bedrooms     Int?
  bathrooms    Int?
  floor        Int?
  totalFloors  Int?
  squareFeet   Int?
  sizeSqm      Float?
  furnished    Boolean?
  parking      Boolean?
  amenities    String[]
  address      String
  hasGarage    Boolean?
  hasGarden    Boolean?
  website      String?
  region       String
  city         String
  county       String
  images       String[]
  maGaday      Boolean   @default(false)
  isBasic30    Boolean   @default(false)
  isStandard60 Boolean   @default(false)
  isPremium90  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isPaid       Boolean   @default(false)
  expiryDate   DateTime?
  feeId        String?   @unique
  feeAmount    Float     @default(0)
  planId       String?
  planAmount   Float     @default(0)

  user         User      @relation("UserRealEstates", fields: [userId], references: [id], onDelete: Cascade)
  payments     Payment[] @relation("RealEstatePayments")
  chats        Chat[]
  messages     Message[] @relation("MessageToRealEstate")
  fee          RealEstateFee? @relation(fields: [feeId], references: [id])
  plan         SubPlan?  @relation(fields: [planId], references: [id])

  @@index([isPaid])
  @@index([createdAt])
  @@index([userId])
  @@index([region])
  @@index([businessId])
}

model Boat {
  id           String    @id @default(cuid())
  userId       String
  businessId   String?
  title        String
  mainCategory String
  category     String[]
  subcategory  String[]
  region       String
  city         String
  description  String
  price        Float
  images       String[]
  type         String
  boatModel    String
  transmission String
  color        String
  website      String?
  maGaday      Boolean   @default(false)
  isBasic30    Boolean   @default(false)
  isStandard60 Boolean   @default(false)
  isPremium90  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isPaid       Boolean   @default(false)
  expiryDate   DateTime?
  feeId        String?   @unique
  feeAmount    Float     @default(0)
  planId       String?
  planAmount   Float     @default(0)

  user         User      @relation("UserBoats", fields: [userId], references: [id], onDelete: Cascade)
  payments     Payment[] @relation("BoatPayments")
  chats        Chat[]
  fee          BoatFee?  @relation(fields: [feeId], references: [id])
  plan         SubPlan?  @relation(fields: [planId], references: [id])

  @@index([isPaid])
  @@index([createdAt])
  @@index([userId])
  @@index([region])
  @@index([businessId])
}

model Car {
  id           String    @id @default(cuid())
  userId       String
  businessId   String?
  title        String
  description  String
  price        Float
  mainCategory String
  category     String[]
  subcategory  String[]
  brand        String
  vehicleModel String
  make         String?
  model        String?
  trim         String?
  year         Int?
  mileage      Int?
  transmission String?
  gearbox      String?
  fuelType     String?
  engineSize   String?
  condition    String?
  color        String
  doors        Int?
  website      String?
  region       String
  city         String
  images       String[]
  maGaday      Boolean   @default(false)
  isBasic30    Boolean   @default(false)
  isStandard60 Boolean   @default(false)
  isPremium90  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isPaid       Boolean   @default(false)
  expiryDate   DateTime?
  feeId        String?   @unique
  feeAmount    Float     @default(0)
  planId       String?
  planAmount   Float     @default(0)

  user         User      @relation("UserCars", fields: [userId], references: [id], onDelete: Cascade)
  payments     Payment[] @relation("CarPayments")
  chats        Chat[]
  fee          CarFee?   @relation(fields: [feeId], references: [id])
  plan         SubPlan?  @relation(fields: [planId], references: [id])

  @@index([isPaid])
  @@index([createdAt])
  @@index([userId])
  @@index([region])
  @@index([businessId])
}

model Motorcycle {
  id           String    @id @default(cuid())
  userId       String
  businessId   String?
  title        String
  transmission String?
  gearbox      String?
  mainCategory String
  category     String[]
  subcategory  String[]
  price        Float
  region       String
  city         String
  images       String[]
  type         String
  make         String
  modelName    String
  model        String?
  year         Int
  mileage      Int
  engineSize   String
  engineCc     String?
  fuelType     String
  color        String
  condition    String?
  description  String
  website      String?
  maGaday      Boolean   @default(false)
  isBasic30    Boolean   @default(false)
  isStandard60 Boolean   @default(false)
  isPremium90  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isPaid       Boolean   @default(false)
  expiryDate   DateTime?
  feeId        String?   @unique
  feeAmount    Float     @default(0)
  planId       String?
  planAmount   Float     @default(0)

  user         User           @relation("UserMotorcycles", fields: [userId], references: [id], onDelete: Cascade)
  payments     Payment[]      @relation("MotorcyclePayments")
  chats        Chat[]
  fee          MotorcycleFee? @relation(fields: [feeId], references: [id])
  plan         SubPlan?       @relation(fields: [planId], references: [id])

  @@index([isPaid])
  @@index([createdAt])
  @@index([userId])
  @@index([region])
  @@index([businessId])
}

model Farmequipment {
  id                  String    @id @default(cuid())
  userId              String
  businessId          String?
  title               String
  description         String
  price               Float
  mainCategory        String
  category            String[]
  subcategory         String[]
  type                String
  equipmentType       String?
  make                String
  brand               String?
  farmequipmentModel  String
  year                Int
  condition           String
  hours               Int?
  hoursUsed           Int?
  lastServiceDate     DateTime?
  attachmentsIncluded Boolean?
  enginePower         String
  fuelType            String
  website             String?
  region              String
  city                String
  images              String[]
  maGaday       Boolean   @default(false)
  isBasic30     Boolean   @default(false)
  isStandard60  Boolean   @default(false)
  isPremium90   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isPaid        Boolean   @default(false)
  expiryDate    DateTime?
  feeId         String?   @unique
  feeAmount     Float     @default(0)
  planId        String?
  planAmount    Float     @default(0)

  user          User      @relation("UserFarmequipments", fields: [userId], references: [id], onDelete: Cascade)
  payments      Payment[] @relation("FarmPayments")
  chats         Chat[]
  fee           EquipmentFeeConfig? @relation(fields: [feeId], references: [id])
  plan          SubPlan?  @relation(fields: [planId], references: [id])

  @@index([isPaid])
  @@index([createdAt])
  @@index([userId])
  @@index([region])
  @@index([businessId])
}

model Job {
  id              String        @id @default(cuid())
  userId          String
  title           String
  description     String
  salary          Float
  mainCategory    String
  category        String[]
  subcategory     String[]
  region          String
  city            String
  employmentType  String
  experienceLevel String
  images          String[]
  maGaday         Boolean       @default(false)
  isBasic30       Boolean       @default(false)
  isStandard60    Boolean       @default(false)
  isPremium90     Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  isPaid          Boolean       @default(false)
  expiryDate      DateTime?
  feeId           String?       @unique
  feeAmount       Float         @default(0)
  planId          String?
  planAmount      Float         @default(0)

  user            User          @relation("UserJobs", fields: [userId], references: [id], onDelete: Cascade)
  payments        Payment[]     @relation("JobPayments")
  chats           Chat[]
  fee             JobFeeConfig? @relation("JobToJobFee", fields: [feeId], references: [id])
  plan            SubPlan?      @relation("JobToSubPlan", fields: [planId], references: [id])

  @@index([isPaid])
  @@index([createdAt])
  @@index([userId])
  @@index([region])
}
model Chat {
  id            Int          @id @default(autoincrement())
  boatId        String?
  carId         String?
  motorcycleId  String?
  realEstateId  String?
  marketplaceId String?
  traktorId     String?
  senderId      String
  receiverId    String
  isArchived    Boolean      @default(false)
  archivedAt    DateTime?
  archivedBy    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  lastMessageAt DateTime?
  boat          Boat?        @relation(fields: [boatId], references: [id])
  car           Car?         @relation(fields: [carId], references: [id])
  marketplace   Marketplace? @relation(fields: [marketplaceId], references: [id])
  motorcycle    Motorcycle?  @relation(fields: [motorcycleId], references: [id])
  realEstate    RealEstate?  @relation(fields: [realEstateId], references: [id])
  receiver      User         @relation("receiverChats", fields: [receiverId], references: [id])
  sender        User         @relation("senderChats", fields: [senderId], references: [id])
  farmequipmentId String?
  farmequipment Farmequipment?     @relation(fields: [farmequipmentId], references: [id])
  messages      Message[]
  jobs          Job[]

  @@unique([senderId, receiverId, boatId])
  @@unique([senderId, receiverId, carId])
  @@unique([senderId, receiverId, motorcycleId])
  @@unique([senderId, receiverId, realEstateId])
  @@unique([senderId, receiverId, marketplaceId])
  @@unique([senderId, receiverId, farmequipmentId])
  @@index([senderId, receiverId])
  @@index([updatedAt])
  @@index([isArchived])
}

model Message {
  id           Int           @id @default(autoincrement())
  chatId       Int
  senderId     String
  receiverId   String
  content      String
  imageUrl     String?
  read         Boolean       @default(false)
  readAt       DateTime?
  edited       Boolean       @default(false)
  editedAt     DateTime?
  deleted      Boolean       @default(false)
  deletedAt    DateTime?
  deletedBy    String?
  replyToId    Int?
  timestamp    DateTime      @default(now())
  chat         Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  receiver     User          @relation("ReceivedMessages", fields: [receiverId], references: [id])
  replyTo      Message?      @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      Message[]     @relation("MessageReplies")
  sender       User          @relation("SentMessages", fields: [senderId], references: [id])
  marketplaces Marketplace[] @relation("MarketplaceToMessage")
  realEstates  RealEstate[]  @relation("MessageToRealEstate")

  @@index([chatId])
  @@index([senderId])
  @@index([receiverId, read])
  @@index([timestamp])
  @@index([chatId, timestamp])
}

model CustomerSupportTicket {
  id          Int             @id @default(autoincrement())
  senderName  String
  senderEmail String
  subject     String
  body        String
  status      Status          @default(NEW)
  priority    String          @default("NORMAL")
  adminReply  String?
  assignedTo  String?
  resolvedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  messages    TicketMessage[]

  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

model TicketMessage {
  id          Int                   @id @default(autoincrement())
  ticketId    Int
  senderRole  Role                  @default(USER)
  senderName  String
  senderEmail String
  body        String
  attachments Json?
  createdAt   DateTime              @default(now())
  ticket      CustomerSupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
}


model Report {
  id          String       @id @default(cuid())
  reason      String
  details     String?
  description String?
  status      Status       @default(NEW)
  itemType    ItemCategory
  itemId      String
  reporterId  String
  reviewedBy  String?
  reviewedAt  DateTime?
  resolution  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user        User         @relation("UserReports", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
  @@index([itemType])
  @@index([itemId])
  @@index([reporterId])
  @@index([reviewedBy])
}
model Subscription {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation("UserSubscriptions", fields: [userId], references: [id], onDelete: Cascade)
  
  title             String
  category          String
  subCategory       String?
  description       String?
  
  region            String
  cities            String[]
  
  priceMin          Int?
  priceMax          Int?
  totalFee          Float?
  isPaid            Boolean   @default(false)
  paymentId         String?
  payments          Payment[] @relation("SubscriptionPayments")
  expiryDate        DateTime?
  
  condition         String?
  brand             String?
  model             String?
  specificFeatures  String?
  
  isActive          Boolean   @default(true)
  status            String    @default("active")
  lastNotified      DateTime?
  read              Boolean   @default(false)
  notificationCount Int       @default(0)
  
  selectedCityIds   String[]
  customCities      String[]
  
  metadata          Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  notifications     Notification[] @relation("SubscriptionNotifications")

  @@index([userId])
  @@index([category, subCategory])
  @@index([isActive])
  @@index([status])
  @@index([region])
  @@index([cities])
  @@index([createdAt])
  @@index([expiryDate])
}

model Notification {
  id             String    @id @default(cuid())
  userId         String
  senderId       String?   
  subscriptionId String?   
  title          String
  message        String
  category       String    
  subCategory    String?
  itemId         String?   
  itemType       String?   
  region         String?
  city           String?
  isRead         Boolean   @default(false)
  isDelivered    Boolean   @default(false)
  readAt         DateTime?
  metadata       Json?     
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User        @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  sender         User?       @relation("SentNotifications", fields: [senderId], references: [id], onDelete: SetNull)
  subscription   Subscription? @relation("SubscriptionNotifications", fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([senderId])
  @@index([subscriptionId])
  @@index([createdAt])
  @@index([isRead])
  @@index([itemId, itemType])
}
model Favorite {
  id          String   @id @default(cuid())
  userId      String
  itemId      String?
  title       String
  description String
  price       String?
  image       String?
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation("UserFavorites", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, itemId])
}

model Recommendation {
  id         Int    @id @default(autoincrement())
  externalId String
  source     String
  category   String
  title      String
  price      String
  views      Int    @default(0)
}

model SearchLog {
  id        String   @id @default(cuid())
  query     String
  category  String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  

  @@index([userId])
}
enum ItemCategory {
  CAR
  REAL_ESTATE
  BOAT
  MOTORCYCLE
  TRAKTOR
  MARKETPLACE
  SUBSCRIPTION
}

enum Status {
  NEW
  IN_PROGRESS
  DONE
  RESOLVED
  CLOSED
}

enum Role {
  USER
  SUPPORT_MANAGER
  ADMIN
}

enum ListingType {
  FREE
  FEE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Payment {
  id              String         @id @default(cuid())
  userId          String
  transactionId   String?        @unique
  paymentMethod   String?
  payerPhone      String?
  currency        String         @default("USD")
  feeAmount       Float          @default(0.00)
  planAmount      Float          @default(0.00)
  taxAmount       Float          @default(0.00)
  platformFee     Float          @default(0.00)
  totalAmount     Float          @default(0.00)
  status          PaymentStatus  @default(PENDING)
  listingType     ListingType    @default(FEE)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  paidAt          DateTime?
  
  marketplaceId   String?
  realEstateId    String?
  boatId          String?
  carId           String?
  motorcycleId    String?
  farmequipmentId String?
  jobId           String?
  subscriptionId   String?
  businessId       String?
  businessPlanId   String?
  marketplaceFeeId String?
  realEstateFeeId String?
  boatFeeId       String?
  carFeeId        String?
  motorcycleFeeId String?
  equipmentFeeId  String?
  jobFeeId        String?
  planConfigId    String?

  user            User           @relation("UserPayments", fields: [userId], references: [id], onDelete: Cascade)
  marketplace     Marketplace?   @relation("MarketplacePayments", fields: [marketplaceId], references: [id])
  realEstate      RealEstate?    @relation("RealEstatePayments", fields: [realEstateId], references: [id])
  boat            Boat?          @relation("BoatPayments", fields: [boatId], references: [id])
  car             Car?           @relation("CarPayments", fields: [carId], references: [id])
  motorcycle      Motorcycle?    @relation("MotorcyclePayments", fields: [motorcycleId], references: [id])
  farmequipment   Farmequipment? @relation("FarmPayments", fields: [farmequipmentId], references: [id])
  job             Job?           @relation("JobPayments", fields: [jobId], references: [id])
  subscription    Subscription?  @relation("SubscriptionPayments", fields: [subscriptionId], references: [id])
  businessPlan    BusinessPlan?  @relation("PaymentBusinessPlan", fields: [businessPlanId], references: [id])

  marketplaceFee  MarketplaceFee?   @relation("PaymentMarketplaceFee", fields: [marketplaceFeeId], references: [id])
  realEstateFee   RealEstateFee?    @relation("PaymentRealEstateFee", fields: [realEstateFeeId], references: [id])
  boatFee         BoatFee?          @relation("PaymentBoatFee", fields: [boatFeeId], references: [id])
  carFee          CarFee?           @relation("PaymentCarFee", fields: [carFeeId], references: [id])
  motorcycleFee   MotorcycleFee?    @relation("PaymentMotorcycleFee", fields: [motorcycleFeeId], references: [id])
  equipmentFee    EquipmentFeeConfig? @relation("PaymentEquipmentFee", fields: [equipmentFeeId], references: [id])
  jobFee          JobFeeConfig?     @relation("PaymentJobFee", fields: [jobFeeId], references: [id])
  planConfig      SubPlan?          @relation("PaymentSubPlan", fields: [planConfigId], references: [id])

  @@index([status])
  @@index([transactionId])
  @@index([userId])
  @@index([marketplaceId])
  @@index([realEstateId])
  @@index([boatId])
  @@index([carId])
  @@index([motorcycleId])
  @@index([farmequipmentId])
  @@index([jobId])
  @@index([marketplaceFeeId])
  @@index([realEstateFeeId])
  @@index([boatFeeId])
  @@index([carFeeId])
  @@index([motorcycleFeeId])
  @@index([equipmentFeeId])
  @@index([jobFeeId])
  @@index([planConfigId])
  @@index([businessId])
  @@index([businessPlanId])
}

model MarketplaceFee {
  id          String   @id @default(cuid())
  art         Float    @default(0.0)
  electronics Float    @default(0.0)
  animal      Float    @default(0.0)
  sports      Float    @default(0.0)
  furniture   Float    @default(0.0)
  fashion     Float    @default(0.0)
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  
  marketplaces Marketplace[]
  payments     Payment[] @relation("PaymentMarketplaceFee")
  changeLogs   FeeChangeLog[]
}

model RealEstateFee {
  id        String   @id @default(cuid())
  rent      Float    @default(0.0)
  sale      Float    @default(0.0)
  land      Float    @default(0.0)
  farm      Float    @default(0.0)
  business  Float    @default(0.0)
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
  
  realEstates RealEstate[]
  payments    Payment[] @relation("PaymentRealEstateFee")
  changeLogs  FeeChangeLog[]
}

model CarFee {
  id          String   @id @default(cuid())
  carSale     Float    @default(0.0)
  carRent     Float    @default(0.0)
  trailer     Float    @default(0.0)
  carParts    Float    @default(0.0)
  truck       Float    @default(0.0)
  electricCar Float    @default(0.0)
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  
  cars        Car[]
  payments    Payment[] @relation("PaymentCarFee")
  changeLogs  FeeChangeLog[]
}

model MotorcycleFee {
  id          String   @id @default(cuid())
  motoSale    Float    @default(0.0)
  motoRent    Float    @default(0.0)
  motoParts   Float    @default(0.0)
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  
  motorcycles Motorcycle[]
  payments    Payment[] @relation("PaymentMotorcycleFee")
  changeLogs  FeeChangeLog[]
}

model BoatFee {
  id         String   @id @default(cuid())
  boatSale   Float    @default(0.0)
  boatRent   Float    @default(0.0)
  boatEngine Float    @default(0.0)
  boatParts  Float    @default(0.0)
  isActive   Boolean  @default(true)
  updatedAt  DateTime @updatedAt
  
  boats      Boat[]
  payments   Payment[] @relation("PaymentBoatFee")
  changeLogs FeeChangeLog[]
}

model EquipmentFeeConfig {
  id          String   @id @default(cuid())
  tractorSale Float    @default(0.0)
  agriTool    Float    @default(0.0)
  harvester   Float    @default(0.0)
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  
  farmequipments Farmequipment[]
  payments       Payment[] @relation("PaymentEquipmentFee")
  changeLogs     FeeChangeLog[]
}

model JobFeeConfig {
  id          String   @id @default(cuid())
  fullTime    Float    @default(0.0)
  partTime    Float    @default(0.0)
  freelance   Float    @default(0.0)
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  
  jobs        Job[]    @relation("JobToJobFee")
  payments    Payment[] @relation("PaymentJobFee")
  changeLogs  FeeChangeLog[]
}

model SystemConfig {
  id          String   @id @default(cuid())
  taxRate     Float    @default(0.0)
  platformFee Float    @default(0.0)
  waafiFee    Float    @default(0.0)
  currency    String   @default("USD")
  updatedAt   DateTime @updatedAt
  changeLogs  FeeChangeLog[]
}
model BusinessPlan {
  id           String     @id @default(cuid())
  name         String
  price        Float
  durationDays Int        @default(30)
  maxListings  Int        @default(10)
  categories   String[]
  features     String[]
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  businesses   Business[]
  payments     Payment[]  @relation("PaymentBusinessPlan")

  @@index([isActive])
}

model SubPlan {
  id             String   @id @default(cuid())
  basic30        Float    @default(0.0)
  standard60     Float    @default(0.0)
  premium90      Float    @default(0.0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  marketplaces   Marketplace[]
  realEstates    RealEstate[]
  boats          Boat[]
  cars           Car[]
  motorcycles    Motorcycle[]
  farmequipments Farmequipment[]
  jobs           Job[]     @relation("JobToSubPlan")
  payments       Payment[] @relation("PaymentSubPlan")
  changeLogs     FeeChangeLog[]
}

model FeeChangeLog {
  id             String    @id @default(cuid())
  feeConfigId    String
  changedBy      String
  changes        Json
  previousValues Json
  newValues      Json
  reason         String?
  createdAt      DateTime  @default(now())

  changedByUser  User      @relation(fields: [changedBy], references: [id])
  
  systemConfig   SystemConfig?   @relation(fields: [feeConfigId], references: [id], map: "log_sys_config")
  subPlan        SubPlan?        @relation(fields: [feeConfigId], references: [id], map: "log_sub_plan")
  marketplaceFee MarketplaceFee? @relation(fields: [feeConfigId], references: [id], map: "log_market_fee")
  realEstateFee  RealEstateFee?  @relation(fields: [feeConfigId], references: [id], map: "log_estate_fee")
  carFee         CarFee?         @relation(fields: [feeConfigId], references: [id], map: "log_car_fee")
  motorcycleFee  MotorcycleFee?  @relation(fields: [feeConfigId], references: [id], map: "log_motorcycle_fee")
  boatFee        BoatFee?        @relation(fields: [feeConfigId], references: [id], map: "log_boat_fee")
  equipmentFee   EquipmentFeeConfig? @relation(fields: [feeConfigId], references: [id], map: "log_equip_fee")
  jobFee         JobFeeConfig?   @relation(fields: [feeConfigId], references: [id], map: "log_job_fee")

  @@index([feeConfigId])
}
model Region {
  id     String @id
  name   String
  cities City[]
}

model City {
  id       String  @id
  name     String
  regionId String
  region   Region  @relation(fields: [regionId], references: [id])
  isActive Boolean @default(true)
}
