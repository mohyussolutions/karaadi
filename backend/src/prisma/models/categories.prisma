model Marketplace {
  id           String    @id @default(cuid())
  userId       String
  title        String
  so           String?
  description  String
  price        Float
  mainCategory String
  category     String[]
  subcategory  String[]
  region       String
  city         String
  district     String
  subDistrict  String?
  images       String[]
  extra        Json?
  maGaday      Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isPaid       Boolean   @default(false)
  chats        Chat[]
  user         User      @relation("UserMarketplaces", fields: [userId], references: [id], onDelete: Cascade)
  Payment      Payment[]
  messages     Message[] @relation("MarketplaceToMessage")
}

model RealEstate {
  id           String    @id @default(cuid())
  userId       String
  title        String
  description  String
  price        Float
  mainCategory String
  category     String[]
  subcategory  String[]
  bedrooms     Int?
  bathrooms    Int?
  squareFeet   Int?
