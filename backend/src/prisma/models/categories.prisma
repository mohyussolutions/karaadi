model Marketplace {
  id           String    @id @default(cuid())
  userId       String
  title        String
  so           String?
  description  String
  price        Float
  mainCategory String
  category     String[]
  subcategory  String[]
  region       String
  city         String
  images       String[]
  extra        Json?
  maGaday      Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isPaid       Boolean   @default(false)
  expiryDate   DateTime?
  feeId        String?
  feeAmount    Float     @default(0)
  planId       String?
  planAmount   Float     @default(0)
  
  user         User      @relation("UserMarketplaces", fields: [userId], references: [id], onDelete: Cascade)
  payments     Payment[] @relation("MarketplacePayments")
  chats        Chat[]
  messages     Message[] @relation("MarketplaceToMessage")
  fee          MarketplaceFee? @relation(fields: [feeId], references: [id])
  plan         SubPlan?  @relation(fields: [planId], references: [id])

  @@index([isPaid])
  @@index([createdAt])
  @@index([userId])
  @@index([region])
  @@index([feeId])
  @@index([planId])
}

