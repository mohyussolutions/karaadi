  hasGarage    Boolean?
  hasGarden    Boolean?
  region       String
  so           String?
  city         String
  county       String
  district     String
  subDistrict  String
  images       String[]
  maGaday      Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isPaid       Boolean   @default(false)
  chats        Chat[]
  payments     Payment[]
  user         User      @relation("UserRealEstates", fields: [userId], references: [id], onDelete: Cascade)
  messages     Message[] @relation("MessageToRealEstate")
}

