model MarketplaceCategory {
  id            String                   @id @default(cuid())
  key           String                   @unique
  nameEn        String
  nameSo        String
  createdAt     DateTime                 @default(now())
  subcategories MarketplaceSubcategory[]
}

model MarketplaceSubcategory {
  id          String              @id @default(cuid())
  key         String
  nameEn      String
  nameSo      String
  categoryKey String
  category    MarketplaceCategory @relation(fields: [categoryKey], references: [key], onDelete: Cascade)
  createdAt   DateTime            @default(now())

  @@unique([key, categoryKey])
}
